<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>لعبة المستحيل - مقالب</title>
    <link href="https://fonts.font.im/css2?family=Tajawal:wght@700;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Tajawal', sans-serif; user-select: none; }
        body { background-color: #111; color: white; overflow: hidden; touch-action: none; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; }
        
        #gameContainer { position: relative; width: 100%; max-width: 800px; height: 100%; max-height: 600px; background: #87CEEB; box-shadow: 0 0 20px rgba(0,0,0,0.8); overflow: hidden; }
        canvas { display: block; width: 100%; height: 100%; }
        
        /* واجهة اللعبة */
        .hud { position: absolute; top: 10px; left: 10px; right: 10px; display: flex; justify-content: space-between; font-size: 24px; font-weight: 900; color: #333; text-shadow: 2px 2px 0 #fff; z-index: 10; pointer-events: none; }
        .death-counter { color: #d32f2f; }
        
        /* رسائل الموت المستفزة */
        #trollMessage { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 40px; color: #ff2a5f; font-weight: 900; z-index: 20; text-align: center; padding: 20px; display: none; }
        .meme-text { font-size: 50px; margin-bottom: 20px; color: #fff; text-shadow: 0 0 10px #ff0000; }
        
        /* أزرار الموبايل */
        .mobile-controls { position: absolute; bottom: 20px; left: 0; width: 100%; display: flex; justify-content: space-between; padding: 0 20px; z-index: 15; }
        .dir-controls { display: flex; gap: 15px; }
        .m-btn { width: 60px; height: 60px; background: rgba(0, 0, 0, 0.4); border: 3px solid rgba(255,255,255,0.8); border-radius: 15px; color: white; font-size: 30px; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
        .m-btn:active { background: rgba(255, 255, 255, 0.8); color: black; transform: scale(0.9); }
        .jump-btn { width: 80px; border-radius: 50%; background: rgba(255, 42, 95, 0.5); border-color: #ff2a5f; }
        
        /* تأثير اهتزاز الشاشة عند الخسارة */
        @keyframes shake { 0% { transform: translate(10px, 10px); } 25% { transform: translate(-10px, -10px); } 50% { transform: translate(10px, -10px); } 75% { transform: translate(-10px, 10px); } 100% { transform: translate(0, 0); } }
        .shaking { animation: shake 0.3s; }
    </style>
</head>
<body>

    <div id="gameContainer">
        <div class="hud">
            <div id="levelText">المرحلة: 1</div>
            <div class="death-counter">عداد الغباء: <span id="deathCount">0</span> 💀</div>
        </div>
        
        <div id="trollMessage">
            <div class="meme-text" id="memeText">عبالك تفوز بسهولة؟ 😂</div>
            <div style="font-size: 20px; color: #aaa;">(جاري الإعادة...)</div>
        </div>

        <canvas id="gameCanvas" width="800" height="600"></canvas>
        
        <div class="mobile-controls">
            <div class="dir-controls">
                <div class="m-btn" id="btnLeft">←</div>
                <div class="m-btn" id="btnRight">→</div>
            </div>
            <div class="m-btn jump-btn" id="btnJump">↑</div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const trollMessage = document.getElementById('trollMessage');
        const memeText = document.getElementById('memeText');
        const deathCountEl = document.getElementById('deathCount');
        const levelText = document.getElementById('levelText');
        const gameContainer = document.getElementById('gameContainer');

        // جمل مستفزة عند الخسارة بالعراقي
        const trollQuotes = [
            "عبالك سهلة؟ 😂", "شنو هالغباء! ركز 🤦‍♂️", "وين رايح يمعود؟ 🤣", 
            "هذا الفخ للطيبين بس 🤡", "كم مرة متت لهسه؟ 💀", "أخوي الصغير يلعب أحسن منك 👶",
            "انتبه للمخفي يا ذكي 🕵️‍♂️", "العب زين لا افصل النت 🔌"
        ];

        let deaths = 0;
        let currentLevel = 1;
        let gameLoop;
        let isDead = false;

        // إعدادات اللاعب
        let player = { x: 50, y: 400, w: 30, h: 30, vx: 0, vy: 0, speed: 5, jumpPower: -12, grounded: false, color: '#ff2a5f' };
        
        // المتغيرات الأساسية للمراحل
        let gravity = 0.6;
        let platforms = [];
        let traps = [];
        let triggers = [];
        let flag = { x: 700, y: 450, w: 40, h: 50 };
        let keys = {};

        // ------------------ تصميم المراحل ------------------
        function loadLevel(level) {
            player.x = 50; player.y = 300; player.vx = 0; player.vy = 0; isDead = false;
            platforms = []; traps = []; triggers = [];
            levelText.innerText = `المرحلة: ${level}`;

            if (level === 1) {
                // المرحلة الأولى: المربع المخفي قبل الحفرة
                platforms.push({ x: 0, y: 500, w: 300, h: 100, type: 'solid', color: '#8B4513' });
                platforms.push({ x: 450, y: 500, w: 350, h: 100, type: 'solid', color: '#8B4513' });
                
                // المربع المخفي (المقلب)
                platforms.push({ x: 260, y: 350, w: 40, h: 40, type: 'hidden', revealed: false, color: '#FFD700' });
                
                // حفرة الموت
                traps.push({ x: 300, y: 580, w: 150, h: 20, type: 'death' });
                flag = { x: 700, y: 450, w: 40, h: 50 };
            } 
            else if (level === 2) {
                // المرحلة الثانية: العلم الهارب والأرض المكسورة
                platforms.push({ x: 0, y: 500, w: 800, h: 100, type: 'solid', color: '#8B4513' });
                flag = { x: 600, y: 450, w: 40, h: 50 };

                // مقلب تحريك العلم
                triggers.push({
                    x: 450, y: 0, w: 10, h: 600, active: true,
                    action: function() { flag.x = 750; this.active = false; }
                });

                // مقلب الأرض التي تسقط
                triggers.push({
                    x: 550, y: 0, w: 10, h: 600, active: true,
                    action: function() {
                        // إزالة جزء من الأرض
                        platforms[0].w = 550;
                        platforms.push({ x: 700, y: 500, w: 100, h: 100, type: 'solid', color: '#8B4513' });
                        // إضافة مسامير بدل الأرض
                        traps.push({ x: 550, y: 580, w: 150, h: 20, type: 'death' });
                        this.active = false;
                    }
                });
            }
            else if (level === 3) {
                // المرحلة الثالثة: السقف القاتل
                platforms.push({ x: 0, y: 500, w: 800, h: 100, type: 'solid', color: '#8B4513' });
                flag = { x: 700, y: 450, w: 40, h: 50 };

                // فخ السقف
                let fallingCeiling = { x: 300, y: -200, w: 200, h: 450, type: 'trap_block', color: '#555', vy: 0 };
                traps.push(fallingCeiling);

                triggers.push({
                    x: 350, y: 0, w: 10, h: 600, active: true,
                    action: function() { fallingCeiling.vy = 20; this.active = false; }
                });
            }
            else {
                // شاشة الفوز النهائية
                alert("مبروك! أنت أذكى من اللعبة وأخيراً فزت! 🎉");
                deaths = 0; currentLevel = 1; loadLevel(1);
            }
        }

        // ------------------ نظام الفيزياء والتصادم ------------------
        function update() {
            if (isDead) return;

            // الحركة الأفقية
            if (keys['ArrowLeft'] || keys['btnLeft']) player.vx = -player.speed;
            else if (keys['ArrowRight'] || keys['btnRight']) player.vx = player.speed;
            else player.vx = 0;

            // القفز
            if ((keys['ArrowUp'] || keys['btnJump']) && player.grounded) {
                player.vy = player.jumpPower;
                player.grounded = false;
            }

            // تطبيق الجاذبية
            player.vy += gravity;

            // تحديث الموقع الأفقي والتحقق من الاصطدام
            player.x += player.vx;
            for (let p of platforms) {
                if (p.type === 'hidden' && !p.revealed) continue; // لا تتصادم إذا كان مخفي تماماً بالأفقي
                if (checkCollision(player, p)) {
                    if (player.vx > 0) player.x = p.x - player.w;
                    else if (player.vx < 0) player.x = p.x + p.w;
                    player.vx = 0;
                }
            }

            // تحديث الموقع العمودي والتحقق من الاصطدام
            player.y += player.vy;
            player.grounded = false;
            for (let p of platforms) {
                if (checkCollision(player, p)) {
                    if (player.vy > 0) { // السقوط على الأرض
                        if (p.type === 'hidden' && !p.revealed) continue;
                        player.y = p.y - player.h;
                        player.vy = 0;
                        player.grounded = true;
                    } else if (player.vy < 0) { // ضرب الرأس من تحت
                        player.y = p.y + p.h;
                        player.vy = 0;
                        if (p.type === 'hidden') {
                            p.revealed = true; // كشف المقلب!
                            player.vy = 2; // ارتداد لأسفل
                        }
                    }
                }
            }

            // تحديث الفخاخ (السقف الساقط)
            for (let t of traps) {
                if (t.type === 'trap_block') {
                    t.y += t.vy;
                    if (t.y > 50) t.vy = 0; // التوقف عند الأرض
                }
                // الموت
                if (checkCollision(player, t)) die();
            }

            // السقوط خارج الشاشة
            if (player.y > 650) die();

            // التحقق من الحساسات (Triggers)
            for (let t of triggers) {
                if (t.active && checkCollision(player, t)) t.action();
            }

            // الوصول للعلم (الفوز بالمرحلة)
            if (checkCollision(player, flag)) {
                currentLevel++;
                loadLevel(currentLevel);
            }
        }

        // ------------------ نظام الرسم ------------------
        function draw() {
            // تنظيف الشاشة ورسم الخلفية
            ctx.fillStyle = '#87CEEB';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // رسم الأرضيات
            for (let p of platforms) {
                if (p.type === 'hidden' && !p.revealed) continue;
                ctx.fillStyle = p.color;
                ctx.fillRect(p.x, p.y, p.w, p.h);
                // لمسة جمالية (عشب)
                if (p.type === 'solid') {
                    ctx.fillStyle = '#32CD32';
                    ctx.fillRect(p.x, p.y, p.w, 15);
                }
                // شكل البلوك المخفي
                if (p.type === 'hidden' && p.revealed) {
                    ctx.fillStyle = 'black';
                    ctx.font = '24px Arial';
                    ctx.fillText('?', p.x + 10, p.y + 30);
                }
            }

            // رسم الفخاخ
            for (let t of traps) {
                if (t.type === 'death') {
                    // رسم مسامير
                    ctx.fillStyle = '#ff0000';
                    for(let i=0; i<t.w; i+=15) {
                        ctx.beginPath(); ctx.moveTo(t.x+i, t.y+t.h); ctx.lineTo(t.x+i+7.5, t.y); ctx.lineTo(t.x+i+15, t.y+t.h); ctx.fill();
                    }
                } else if (t.type === 'trap_block') {
                    ctx.fillStyle = t.color;
                    ctx.fillRect(t.x, t.y, t.w, t.h);
                }
            }

            // رسم العلم
            ctx.fillStyle = '#FFF';
            ctx.fillRect(flag.x, flag.y, 5, flag.h); // العصا
            ctx.fillStyle = '#32CD32';
            ctx.beginPath(); ctx.moveTo(flag.x+5, flag.y); ctx.lineTo(flag.x+40, flag.y+15); ctx.lineTo(flag.x+5, flag.y+30); ctx.fill(); // الراية

            // رسم اللاعب
            if (!isDead) {
                ctx.fillStyle = player.color;
                ctx.fillRect(player.x, player.y, player.w, player.h);
                // رسم عيون خائفة
                ctx.fillStyle = 'white';
                ctx.fillRect(player.x + 18, player.y + 5, 8, 8);
                ctx.fillStyle = 'black';
                ctx.fillRect(player.x + 22, player.y + 8, 4, 4);
            }
        }

        // ------------------ الموت والخسارة ------------------
        function die() {
            if (isDead) return;
            isDead = true;
            deaths++;
            deathCountEl.innerText = deaths;
            
            // اهتزاز الشاشة
            gameContainer.classList.add('shaking');
            setTimeout(() => gameContainer.classList.remove('shaking'), 300);

            // إظهار الرسالة المستفزة
            memeText.innerText = trollQuotes[Math.floor(Math.random() * trollQuotes.length)];
            trollMessage.style.display = 'flex';

            // إعادة المرحلة بعد ثانية ونصف
            setTimeout(() => {
                trollMessage.style.display = 'none';
                loadLevel(currentLevel);
            }, 1500);
        }

        // مساعدة التصادم
        function checkCollision(r1, r2) {
            return r1.x < r2.x + r2.w && r1.x + r1.w > r2.x &&
                   r1.y < r2.y + r2.h && r1.y + r1.h > r2.y;
        }

        // حلقة اللعبة
        function loop() {
            update();
            draw();
            requestAnimationFrame(loop);
        }

        // ------------------ نظام التحكم ------------------
        window.addEventListener('keydown', e => keys[e.key] = true);
        window.addEventListener('keyup', e => keys[e.key] = false);

        const bindBtn = (id, key) => {
            const btn = document.getElementById(id);
            btn.addEventListener('touchstart', (e) => { e.preventDefault(); keys[key] = true; });
            btn.addEventListener('touchend', (e) => { e.preventDefault(); keys[key] = false; });
            btn.addEventListener('mousedown', () => keys[key] = true);
            btn.addEventListener('mouseup', () => keys[key] = false);
            btn.addEventListener('mouseleave', () => keys[key] = false);
        };

        bindBtn('btnLeft', 'btnLeft');
        bindBtn('btnRight', 'btnRight');
        bindBtn('btnJump', 'btnJump');

        // بدء اللعبة
        loadLevel(1);
        loop();
    </script>
</body>
</html>
